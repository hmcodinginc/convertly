/* --------------------------------------------------------------------------
   Auth form page — vertical rhythm & optical balance
   -------------------------------------------------------------------------- */

.auth-form-page {
  display: flex;
  width: 100%;
  flex-direction: column;
}

.auth-form-header {
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
  margin-bottom: 2.25rem;
}

.auth-form-stack {
  display: flex;
  flex-direction: column;
  gap: 1.375rem;
}

.auth-form-footer {
