<file path="client/src/styles/theme.css">
/* ==========================================================================
   Convertly Theme Tokens (Dark Only)
   Minimal, scalable semantic foundation
   ========================================================================== */

:root {
  /* ------------------------------------------------------------------------
     Color Tokens
     ------------------------------------------------------------------------ */
  --background: #090b10;
  --background-elevated: #0e121b;
  --foreground: #e6e9ef;

  --surface: #11141b;
  --card: #141925;
  --surface-elevated: #181d2a;

  --muted: #94a3b8;
  --border: rgba(148, 163, 184, 0.22);

  --accent: #7c6cff;
  --accent-foreground: #f8f9ff;

  /* ------------------------------------------------------------------------
     Gradient Tokens
     ------------------------------------------------------------------------ */
  --gradient-primary: linear-gradient(
    135deg,
    #7c6cff 0%,
    #5d7dff 48%,
    #35b3ff 100%
  );
  --gradient-surface: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.04) 0%,
    rgba(255, 255, 255, 0) 100%
  );
  --gradient-atmosphere: radial-gradient(
      110% 75% at 12% -10%,
      color-mix(in srgb, var(--accent) 14%, transparent),
      transparent 62%
    ),
    radial-gradient(
      85% 65% at 88% -8%,
      rgba(120, 140, 255, 0.08),
      transparent 64%
    ),
    radial-gradient(
      70% 55% at 50% 100%,
      rgba(79, 108, 182, 0.08),
      transparent 72%
    ),
    linear-gradient(180deg, var(--background-elevated) 0%, var(--background) 42%);

  /* ------------------------------------------------------------------------
     Shadow Tokens
     ------------------------------------------------------------------------ */
  --shadow-soft: 0 6px 22px rgba(2, 6, 23, 0.25);
  --shadow-medium: 0 14px 40px rgba(2, 6, 23, 0.32);
  --shadow-glow: 0 0 0 1px rgba(124, 108, 255, 0.2), 0 12px 34px rgba(45, 68, 160, 0.28);

  /* ------------------------------------------------------------------------
     Radius Tokens
     ------------------------------------------------------------------------ */
  --radius-sm: 0.5rem;
  --radius-md: 0.75rem;
  --radius-lg: 1rem;
  --radius-xl: 1.25rem;

  /* ------------------------------------------------------------------------
     Motion Tokens
     ------------------------------------------------------------------------ */
  --motion-fast: 160ms;
  --motion-base: 240ms;
  --motion-slow: 360ms;
  --ease-standard: cubic-bezier(0.22, 1, 0.36, 1);

  /* ------------------------------------------------------------------------
     Layout / Container Tokens
     ------------------------------------------------------------------------ */
  --container-max: 80rem;
  --container-gutter: 1rem;
  --section-space-y: 4rem;
}

@media (min-width: 768px) {
  :root {
    --container-gutter: 1.5rem;
    --section-space-y: 5rem;
  }
}

@media (min-width: 1024px) {
  :root {
    --container-gutter: 2rem;
    --section-space-y: 5rem;
  }
}

/* ==========================================================================
   Reusable Utility Classes
   ========================================================================== */

.container-premium {
  width: min(100% - (var(--container-gutter) * 2), var(--container-max));
  margin-inline: auto;
}

.section-padding {
  padding-block: var(--section-space-y);
}

.app-atmosphere {
  background-color: var(--background);
  background-image: var(--gradient-atmosphere);
  background-repeat: no-repeat;
  background-size: 100% 100%;
}

.glass-surface {
  background:
    linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.09) 0%,
      rgba(255, 255, 255, 0.02) 30%,
      rgba(255, 255, 255, 0) 100%
    ),
    color-mix(in srgb, var(--surface) 70%, transparent);
  border: 1px solid color-mix(in srgb, var(--border) 92%, rgba(255, 255, 255, 0.08));
  border-radius: var(--radius-lg);
  box-shadow:
    inset 0 1px 0 rgba(255, 255, 255, 0.08),
    0 1px 0 rgba(255, 255, 255, 0.04),
    var(--shadow-medium);
  backdrop-filter: blur(14px);
  -webkit-backdrop-filter: blur(14px);
}

.gradient-primary {
  background-image: var(--gradient-primary);
}

.text-gradient {
  background-image: var(--gradient-primary);
  color: transparent;
  -webkit-background-clip: text;
  background-clip: text;
}

body {
  background-color: var(--background);
  background-image: var(--gradient-atmosphere);
  background-repeat: no-repeat;
}
</file>

