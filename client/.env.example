# Convertly environment configuration

# Supabase (production auth)
# Use the project URL root only — not /rest/v1/
# Example: https://your-project-ref.supabase.co
VITE_SUPABASE_URL=
# Settings → API → anon public key (JWT, starts with eyJ...)
VITE_SUPABASE_ANON_KEY=

# Public app URL for auth email redirects (no trailing slash).
# Local: http://localhost:5173
# Staging: https://convertly-qxoh.vercel.app
# When unset, the active browser origin is used at runtime.
VITE_APP_URL=

# Use localStorage-backed auth for local MVP development (default: true)
VITE_USE_LOCAL_AUTH=true

# Optional: local Playwright render worker (no Supabase edge proxy)
# Start with: cd render-worker && npm install && npm run dev
# VITE_AUDIT_RENDER_URL=http://localhost:3100/render
