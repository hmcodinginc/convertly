          <span
            key={segment}
            className={cn(
              "h-1.5 w-4 rounded-full",
              segment <= filled
                ? "bg-[var(--accent)]"
                : "bg-[color-mix(in_srgb,var(--muted)_22%,transparent)]"
            )}
          />
        ))}
      </div>
      <span className="text-[0.62rem] text-foreground/62">{level}</span>
    </div>
