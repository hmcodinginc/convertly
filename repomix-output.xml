        </Heading>
        <Text variant="muted" size="sm" className="max-w-none leading-6">
          Sign in to access your audits, workspace, and conversion insights.
        </Text>
      </div>

      {passwordWasReset ? (
        <AuthFormMessage variant="success">
          Password updated. Sign in with your new password.
