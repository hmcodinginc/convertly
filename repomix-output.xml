            <>
              <Loader2 className="size-4 animate-spin" aria-hidden />
              Signing in…
            </>
          ) : (
            "Sign in"
          )}
        </Button>
      </form>

      <div className="auth-form-footer">
        <Text size="sm" variant="muted" className="max-w-none leading-6">
