.profile-delete-btn {
  border: 1px solid color-mix(in srgb, #ef4444 55%, transparent);
  background: color-mix(in srgb, #ef4444 14%, transparent);
  color: #fecaca;
  box-shadow: none;
}

.profile-delete-btn:hover:not(:disabled) {
  border-color: color-mix(in srgb, #ef4444 75%, transparent);
  background: color-mix(in srgb, #ef4444 26%, transparent);
  color: #fff;
}

.profile-delete-btn svg {
  color: #f87171;
}

.profile-drawer-form {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.profile-drawer-section {
  display: flex;
  flex-direction: column;
  gap: 0.625rem;
}

.profile-drawer-section-title {
  font-size: 0.75rem;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: color-mix(in srgb, var(--muted) 95%, transparent);
}

.profile-drawer-fields {
  display: flex;
  flex-direction: column;
  gap: 0.875rem;
}

.profile-drawer-footer {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 0.5rem;
  margin-top: 0;
  padding-top: 1rem;
  border-top: 1px solid color-mix(in srgb, var(--border) 55%, transparent);
}

.profile-recovery-box {
  border-radius: var(--radius-md);
  border: 1px solid color-mix(in srgb, var(--border) 55%, transparent);
  background: color-mix(in srgb, var(--surface) 45%, transparent);
  padding: 0.75rem 0.875rem;
}

.profile-recovery-text {
  font-size: 0.875rem;
  line-height: 1.55;
  color: color-mix(in srgb, var(--foreground) 72%, transparent);
}

.profile-recovery-link {
  display: inline-flex;
  align-items: center;
  margin-top: 0.5rem;
  font-size: 0.875rem;
  font-weight: 500;
  line-height: 1.4;
  color: color-mix(in srgb, var(--foreground) 90%, transparent);
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: color 0.15s ease;
}

.profile-recovery-link:hover:not(:disabled) {
  color: var(--foreground);
}

.profile-recovery-link:disabled {
  cursor: not-allowed;
  opacity: 0.55;
}

.profile-delete-terms-scroll {
  max-height: 5.5rem;
  overflow-y: auto;
  border-radius: var(--radius-md);
  border: 1px solid color-mix(in srgb, var(--border) 55%, transparent);
  background: color-mix(in srgb, var(--surface) 35%, transparent);
