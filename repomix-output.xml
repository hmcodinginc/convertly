}

.auth-form-success-panel {
  display: flex;
  flex-direction: column;
  gap: 1.375rem;
}

/* --------------------------------------------------------------------------
   Auth shell — responsive column / grid
   -------------------------------------------------------------------------- */

.auth-layout-grid {
  display: flex;
  width: 100%;
  min-height: 0;
  flex-direction: column;
}

.auth-layout-grid > .auth-form-column {
  order: 1;
}

.auth-layout-grid > .auth-showcase {
  order: 2;
}

/* --------------------------------------------------------------------------
   Showcase panel (left on desktop, below form on mobile)
   -------------------------------------------------------------------------- */

.auth-showcase {
  position: relative;
  isolation: isolate;
  background-color: color-mix(in srgb, var(--background) 94%, transparent);
}

.auth-showcase::before {
  content: "";
  pointer-events: none;
  position: absolute;
  inset: 0;
  background:
    radial-gradient(
      90% 70% at 10% 0%,
      color-mix(in srgb, var(--accent) 16%, transparent),
      transparent 62%
    ),
    radial-gradient(
      70% 55% at 90% 100%,
      rgba(79, 108, 182, 0.1),
      transparent 68%
    );
}

.auth-showcase-stage {
  position: relative;
  min-height: 0;
  flex: 1 1 auto;
}

.auth-showcase-slide {
  position: absolute;
  inset: 0;
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
