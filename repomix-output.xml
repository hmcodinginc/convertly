function createSession(userId: string, websiteUrl: string): AuditSession {
  const now = new Date().toISOString()
  const session: AuditSession = {
    id: createId(),
    userId,
    websiteUrl,
    createdAt: now,
    updatedAt: now,
    status: "pending",
  }

  const sessions = loadSessions()
  saveSessions([session, ...sessions])
