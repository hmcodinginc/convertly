      </div>
      <div className="grid grid-cols-3 gap-2 text-[0.62rem] text-foreground/58">
        <span>High {high}</span>
        <span className="text-center">Med {medium}</span>
        <span className="text-right">Low {low}</span>
      </div>
    </div>
  )
}

function MonitoringHeatmap() {
