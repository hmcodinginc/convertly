  font-size: 0.8125rem;
  line-height: 1.55;
  color: color-mix(in srgb, var(--foreground) 75%, transparent);
}

.profile-delete-modal-body {
  display: flex;
  flex-direction: column;
  gap: 1.25rem;
}

.profile-delete-modal-footer {
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
}

.profile-delete-modal-actions {
  display: flex;
  flex-wrap: wrap;
  justify-content: flex-end;
  gap: 0.5rem;
