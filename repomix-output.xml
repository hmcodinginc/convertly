  { pageType: "homepage", paths: ["/", "/home"], title: "Homepage" },
  { pageType: "pricing", paths: ["/pricing", "/plans", "/price"], title: "Pricing" },
  { pageType: "about", paths: ["/about", "/about-us", "/company"], title: "About" },
