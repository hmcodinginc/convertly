  flex-direction: column;
  gap: 0.875rem;
}

.auth-form-submit {
  min-height: 2.5rem;
}

.auth-form-inline-link {
  display: flex;
  justify-content: flex-end;
  margin-top: -0.25rem;
}

/* Field hierarchy — label, input, hint, error */

.auth-field {
