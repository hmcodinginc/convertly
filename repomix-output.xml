}

type AuthShowcaseMetricVisualProps = {
  metricId: string
}

function AuthShowcaseMetricVisual({ metricId }: AuthShowcaseMetricVisualProps) {
  if (metricId === "conversion-score") {
    return (
      <div className="space-y-3">
