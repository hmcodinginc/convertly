# Convertly environment configuration

# Supabase (production auth)
# Use the project URL root only — not /rest/v1/
# Example: https://your-project-ref.supabase.co
VITE_SUPABASE_URL=
# Settings → API → anon public key (JWT, starts with eyJ...)
VITE_SUPABASE_ANON_KEY=

# Use localStorage-backed auth for local MVP development (default: true)
VITE_USE_LOCAL_AUTH=true
